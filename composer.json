{
    "name": "octo-php/symfony-messenger",
    "description": "Symfony Messenger transport for the Async PHP Platform — in-process message passing via bounded OpenSwoole channels with backpressure.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "octo-php/runtime-pack": "^0.1",
        "octo-php/symfony-bridge": "^0.1",
        "symfony/messenger": "^6.4|^7.0"
    },
    "require-dev": {
        "giorgiosironi/eris": "^1.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Octo\\SymfonyMessenger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Octo\\SymfonyMessenger\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
