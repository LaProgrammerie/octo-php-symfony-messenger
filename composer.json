{
    "name": "async-platform/symfony-messenger",
    "description": "Symfony Messenger transport for the Async PHP Platform — in-process message passing via bounded OpenSwoole channels with backpressure.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "async-platform/runtime-pack": "@dev",
        "async-platform/symfony-bridge": "@dev",
        "symfony/messenger": "^6.4|^7.0"
    },
    "require-dev": {
        "giorgiosironi/eris": "^1.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AsyncPlatform\\SymfonyMessenger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AsyncPlatform\\SymfonyMessenger\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
